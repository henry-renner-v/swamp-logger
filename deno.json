{
  "name": "swamp-logger",
  "version": "0.1.0",
  "exports": "./swamp_logger.ts",
  "imports": {
    "@std/assert": "jsr:@std/assert@1"
  },
  "tasks": {
    "start": "deno run --allow-net --allow-read --allow-write --allow-env swamp_logger.ts",
    "audit": "deno run --allow-read audit.ts",
    "check": "deno fmt --check && deno lint && deno check *.ts",
    "test": "deno test --allow-read"
  },
  "fmt": {
    "lineWidth": 100
  }
}
